{
  "name": "Functional Website",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [4321, 3333, 4566, 80],
  "portsAttributes": {
    "4321": { "label": "Astro Dev Server" },
    "3333": { "label": "Sanity Studio" },
    "4566": { "label": "LocalStack" },
    "80": { "label": "optimumu.localhost" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[astro]": {
          "editor.defaultFormatter": "astro-build.astro-vscode"
        }
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/localstack/devcontainer-feature/localstack-cli:latest": {
      "version": "latest",
      "awslocal": true
    }
  },
  "postCreateCommand": "npm install"
}
