---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import PillarsSection from '../components/PillarsSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Home" description="Holistic wellness for your optimal self — functional medicine, mindset, and lifestyle.">
  <Header />
  <main>
    <HeroCarousel />
    <PillarsSection />

    <!-- Mission section -->
    <section class="py-24 px-6 text-center max-w-3xl mx-auto">
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-gold)] mb-4">Our Mission</p>
      <h2 class="font-serif text-4xl md:text-5xl text-[var(--color-charcoal)] mb-8 leading-snug">
        You were designed to thrive
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed mb-10">
        OptimumU exists to bridge the gap between conventional medicine and the wisdom of functional, whole-person health. Through evidence-informed guidance and heartfelt community, we help you rediscover what it feels like to be truly well.
      </p>
      <a
        href="/about"
        class="inline-block border border-[var(--color-gold)] text-[var(--color-gold)] text-xs uppercase tracking-[0.2em] px-10 py-4 hover:bg-[var(--color-gold)] hover:text-white transition-all duration-300"
      >
        Our Story
      </a>
    </section>

    <!-- Latest posts -->
    <section class="py-24 bg-[var(--color-cream)]">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-gold)] mb-4">From the Blog</p>
          <h2 class="font-serif text-4xl text-[var(--color-charcoal)]">Latest Articles</h2>
        </div>
        <div class="text-center">
          <a
            href="/blog"
            class="inline-block border border-[var(--color-gold)] text-[var(--color-gold)] text-xs uppercase tracking-[0.2em] px-10 py-4 hover:bg-[var(--color-gold)] hover:text-white transition-all duration-300"
          >
            View All Articles
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
