---
import { toHTML } from '@portabletext/to-html';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { client } from '../../lib/sanity';

export async function getStaticPaths() {
  const posts = await client.fetch(`
    *[_type == "post"] { "slug": slug.current }
  `);
  return posts.map((p: { slug: string }) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

const post = await client.fetch(`
  *[_type == "post" && slug.current == $slug][0] {
    _id,
    title,
    slug,
    excerpt,
    publishedAt,
    body,
    "coverImageRef": coverImage.asset._ref,
    "categories": categories[]->{title, slug}
  }
`, { slug });

if (!post) return Astro.redirect('/blog');

const bodyHtml = post.body ? toHTML(post.body) : '';

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}

function imageUrl(ref: string | undefined, width = 1200): string | null {
  if (!ref) return null;
  const body = ref.replace('image-', '').replace(/-(\w+)$/, '.$1');
  return `https://cdn.sanity.io/images/lk5dzwr6/production/${body}?w=${width}&auto=format`;
}
---

<BaseLayout title={post.title} description={post.excerpt ?? ''}>
  <Header />

  <main class="pt-32 pb-24 min-h-screen">

    <!-- Article header -->
    <header class="bg-[var(--color-cream)] py-16 px-6 text-center">
      <div class="max-w-2xl mx-auto">
        {post.categories?.length > 0 && (
          <p class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-gold)] mb-4">
            {post.categories[0].title}
          </p>
        )}
        <h1 class="font-serif text-4xl md:text-5xl text-[var(--color-charcoal)] leading-tight mb-6">
          {post.title}
        </h1>
        {post.excerpt && (
          <p class="text-gray-500 text-lg leading-relaxed mb-6">{post.excerpt}</p>
        )}
        {post.publishedAt && (
          <time class="text-xs text-gray-400 uppercase tracking-widest" datetime={post.publishedAt}>
            {formatDate(post.publishedAt)}
          </time>
        )}
      </div>
    </header>

    <!-- Cover image -->
    {imageUrl(post.coverImageRef) && (
      <div class="max-w-4xl mx-auto px-6 pt-10">
        <img
          src={imageUrl(post.coverImageRef)!}
          alt={post.title}
          class="w-full max-h-[480px] object-cover"
        />
      </div>
    )}

    <!-- Article body -->
    <div class="max-w-2xl mx-auto px-6 py-16">
      <div class="blog-prose" set:html={bodyHtml} />

      <!-- Back link -->
      <div class="mt-16 pt-8 border-t border-gray-200">
        <a
          href="/blog"
          class="text-xs uppercase tracking-widest text-[var(--color-gold)] hover:underline"
        >
          ← Back to All Articles
        </a>
      </div>
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-prose :global(h2) {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--color-charcoal);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .blog-prose :global(h3) {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--color-charcoal);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .blog-prose :global(p) {
    color: #4b5563;
    line-height: 1.85;
    margin-bottom: 1.25rem;
    font-size: 1.0625rem;
  }

  .blog-prose :global(a) {
    color: var(--color-gold);
    text-decoration: underline;
  }

  .blog-prose :global(ul),
  .blog-prose :global(ol) {
    color: #4b5563;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    line-height: 1.85;
  }

  .blog-prose :global(li) {
    margin-bottom: 0.375rem;
  }

  .blog-prose :global(strong) {
    color: var(--color-charcoal);
    font-weight: 600;
  }

  .blog-prose :global(blockquote) {
    border-left: 3px solid var(--color-gold);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: #6b7280;
    font-style: italic;
  }
</style>
