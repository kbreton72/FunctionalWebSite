---
const pillars = ['Mental', 'Emotional', 'Physical', 'Social', 'Spiritual', 'Financial'];
---

<footer class="bg-[var(--color-charcoal)] text-white/60 py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <div>
        <p class="font-serif text-2xl text-[var(--color-gold)] font-bold mb-4">OptimumU</p>
        <p class="text-sm leading-relaxed mb-6">
          Guiding you toward your optimal self through functional medicine and holistic living.
        </p>
        <a
          href="https://www.instagram.com/_optimumu_/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-white/60 hover:text-[var(--color-gold-light)] transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
          @_optimumu_
        </a>
      </div>

      <div>
        <p class="text-xs uppercase tracking-widest text-white/40 mb-4">The Five Pillars</p>
        <ul class="space-y-2">
          {pillars.map(p => (
            <li>
              <a href={`/pillars/${p.toLowerCase()}`} class="text-sm hover:text-[var(--color-gold-light)] transition-colors">
                Optimum {p} Health
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-xs uppercase tracking-widest text-white/40 mb-4">Explore</p>
        <ul class="space-y-2">
          {['Blog', 'Resources', 'About', 'Contact'].map(item => (
            <li>
              <a href={`/${item.toLowerCase()}`} class="text-sm hover:text-[var(--color-gold-light)] transition-colors">
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs">© {new Date().getFullYear()} OptimumU. All rights reserved.</p>
      <p class="text-xs">
        This site may contain affiliate links. <a href="/affiliate-disclosure" class="underline hover:text-white">Disclosure</a>
      </p>
    </div>
  </div>
</footer>
